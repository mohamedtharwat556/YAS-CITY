{
  "version": 2,
  "rewrites": [
    { "source": "/maintenance", "destination": "/maintenance.html" },
    { "source": "/customer-service", "destination": "/customer-service.html" },
    { "source": "/online", "destination": "/online.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/seo/laptop-repair-damietta", "destination": "/seo/laptop-repair-damietta.html" },
    { "source": "/seo/laptop-sales-damietta", "destination": "/seo/laptop-sales-damietta.html" },
    { "source": "/seo/board-repair-damietta", "destination": "/seo/board-repair-damietta.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
